            y=(1000/2)-(((h*scale)/2)-->F),
            w=(w*scale)-->F,
            h=(h*scale)-->F,
        }
    },
    L = \(w,h,scale) {
        @{
            x=((1500/2)+375)-(((w*scale)/2)-->F),
            y=(1000/2)-(((h*scale)/2)-->F),
            w=(w*scale)-->F,
            h=(h*scale)-->F,
        }
    },
    O = \(w,h,scale) {
