            h=(h*scale)-->F,
        }
    },
    N = \(w,h,scale) {
        @{
            x=(1500/2)-(((w*scale)/2)-->F),
            y=((1000/2)-250)-(((h*scale)/2)-->F),
            w=(w*scale)-->F,
            h=(h*scale)-->F,
        }
    },
    S = \(w,h,scale) {
        @{
            x=(1500/2)-(((w*scale)/2)-->F),
            y=((1000/2)+250)-(((h*scale)/2)-->F),
            w=(w*scale)-->F,
