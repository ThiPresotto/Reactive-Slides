func validatePresentation(p){
    if (type(p) != "table") {
        print("Root must be a table")    
    }

    loop idx, slide in p {
        validateSlide(slide,idx)
    }

}

func validateSlide(slide,idx){
    if (type(slide) != "table"){
        print("Slide "++idx++" must be a table")
    }

    if !slide.template{
        print("Missing <template> field on slide "++idx)
    }

    
        val valid_templates = @{
            FrontCover = true,
            Slide_Title_OneObject = true,
            Slide_Title_TwoObjects = true,
        }

        if !valid_templates[slide.template]{
            print("Invalid slide template in slide "++idx)
        }
    

    match slide.template {
        :FrontCover => {
            validateFrontCover(slide,idx)
        }
        :Slide_Title_OneObject => {
            validateSlideTitleOneObject(slide,idx)
        }
        :Slide_Title_TwoObjects => {
            validateSlideTitleTwoObjects(slide,idx)
        }
    }
}

