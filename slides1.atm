    text = @{
        tiny = 15,
        small = 25,      
        normal = 45, 
        large = 60,   
        giant = 80,
        },
    image = @{
        tiny = 100,
        small = 150,
        normal = 300,
        large = 500,
        giant = 750,
    }
}

