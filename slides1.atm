;;Refletir sobre argumentos em Image. Pos pode ser
;;uma tabela {x,y} ou um valor chave "L" ao mesmo tempo

val M = @{}
set M.height = 0
set M.width = 0

set SDL = require "SDL"
set IMG = require "SDL.image"
set TTF = require "SDL.ttf"
set MIX = require "SDL.mixer"

set sdl = require "atmos.env.sdl"

val F = math.floor

func M.open(win_name,win_width,win_height){
    SDL.init(SDL.flags.video) -->assert
    TTF.init() -->assert
    IMG.init() -->assert 
    MIX.init() -->assert

    ;;set M.height = win_height
    ;;set M.width = win_width

    set WIN = SDL.createWindow @{
        title = win_name,
        height = win_height,
        width = win_width,
        flags = @{ SDL.flags.OpenGL
        }
    } --> assert


    set REN = SDL.createRenderer(WIN, -1) --> assert
    set sdl.ren = REN
}



;;MIX.openAudio(44100, SDL.audioFormat.S16, 2, 1024) --> assert

func M.close(){
    SDL.quit()
    TTF.quit()
    IMG.quit()
    MIX.quit()
}

func M.new_image_size(t){
    var new = @{w = nil, h = nil}
    ifs{
        t.w <= t.h => {
            set new.w = t.ratio
            set new.h = ((t.h/t.w)*new.w)-->F
        }
        t.h < t.w => {
            set new.h = t.ratio
            set new.w = ((t.w/t.h)*new.h)-->F
        }
    }
    new
}

