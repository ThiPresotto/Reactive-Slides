    C = \(length) {
        @{
            x=(1500/2)-(((length.w)/2)-->F),
            y=(1000/2)-(((length.h)/2)-->F),
            w=(length.w)-->F,
            h=(length.h)-->F,
        }
    },
    L = \(length) {
        @{
            x=((1500/2)+375)-(((length.w)/2)-->F),
            y=(1000/2)-(((length.h)/2)-->F),
            w=(length.w)-->F,
            h=(length.h)-->F,
        }
    },
    O = \(length) {
        @{
            x=((1500/2)-375)-(((length.w)/2)-->F),
            y=(1000/2)-(((length.h)/2)-->F),
            w=(length.w)-->F,
            h=(length.h)-->F,
        }
    },
    N = \(length) {
        @{
            x=(1500/2)-(((length.w)/2)-->F),
            y=((1000/2)-250)-(((length.h)/2)-->F),
            w=(length.w)-->F,
            h=(length.h)-->F,
        }
    },
    S = \(length) {
        @{
            x=(1500/2)-(((length.w)/2)-->F),
            y=((1000/2)+250)-(((length.h)/2)-->F),
            w=(length.w)-->F,
            h=(length.h)-->F,
        }
    },
    SL = \(length) {
        @{
            x=((1500/2)+375)-(((length.w)/2)-->F),
            y=((1000/2)+250)-(((length.h)/2)-->F),
            w=(length.w)-->F,
            h=(length.h)-->F,
        }
    },
    SO = \(length) {
        @{
            x=((1500/2)-375)-(((length.w)/2)-->F),
            y=((1000/2)+250)-(((length.h)/2)-->F),
            w=(length.w)-->F,
            h=(length.h)-->F,
        }
    },
    NO = \(length) {
        @{
            x=((1500/2)-375)-(((length.w)/2)-->F),
            y=((1000/2)-250)-(((length.h)/2)-->F),
            w=(length.w)-->F,
            h=(length.h)-->F,
        }
    },
    NL = \(length) {
        @{
            x=((1500/2)+375)-(((length.w)/2)-->F),
            y=((1000/2)-250)-(((length.h)/2)-->F),
            w=(length.w)-->F,
            h=(length.h)-->F,
